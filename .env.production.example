# Copy to .env on the server and fill in real values.
# Regenerate every secret for production — never reuse dev values.

# ---- Postgres ----
POSTGRES_USER=wdms
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_24
POSTGRES_DB=wdms
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Backend ----
APP_ENV=production
APP_DEBUG=false
APP_NAME=Suv24
APP_TIMEZONE=Asia/Tashkent

# ---- Security (CRITICAL) ----
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

# ---- CORS (production domains only) ----
CORS_ORIGINS=https://suv24.uz,https://www.suv24.uz

# ---- Multi-tenancy defaults ----
DEFAULT_COMPANY_SLUG=demo

# ---- Platform owner seed (change before first run) ----
SEED_OWNER_PHONE=+998900000000
SEED_OWNER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_OWNER_NAME=Suv24 Owner

# Default super admin for the demo company (change or remove after first login)
SEED_ADMIN_PHONE=+998900000001
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_ADMIN_NAME=Demo Admin
SEED_COMPANY_NAME=Demo Suv Kompaniyasi

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- Deploy-time (host-side) ----
# Port where backend exposes itself on the host (nginx proxies here).
# Pick any free port on the server — default 8017 may conflict with other projects.
BACKEND_HOST_PORT=8017
UVICORN_WORKERS=3
