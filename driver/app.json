{
  "expo": {
    "name": "Suv24 Go",
    "slug": "buloq-driver",
    "version": "0.1.1",
    "orientation": "portrait",
    "scheme": "suv24go",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#3b82f6",
      "resizeMode": "cover"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.buloq.driver"
    },
    "android": {
      "package": "uz.buloq.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3b82f6"
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9f486a99-6f6a-4689-b3cb-ca54c65ed2e2"
      }
    },
    "owner": "asliddinweb"
  }
}
