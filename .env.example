# ---- Postgres ----
POSTGRES_USER=wdms
POSTGRES_PASSWORD=wdms_dev_password
POSTGRES_DB=wdms
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Backend ----
APP_ENV=development
APP_DEBUG=true
APP_NAME=WDMS
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Tashkent

# ---- Security ----
JWT_SECRET_KEY=change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

# ---- CORS ----
CORS_ORIGINS=http://localhost:8020,http://localhost:5173,http://localhost:19006

# ---- Multi-tenancy defaults ----
DEFAULT_COMPANY_SLUG=demo

# ---- Sentry (optional) ----
SENTRY_DSN=
